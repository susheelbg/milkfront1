# --- DATABASE SETTINGS ---
# Use PostgreSQL asyncPg driver for Supabase DB
DATABASE_URL=postgresql+asyncpg://postgres:your_supabase_password@db.your_supabase_id.supabase.co:5432/postgres

# --- SECURITY / JWT SETTINGS ---
JWT_SECRET=super_secret_jwt_signature_key_change_me_in_production_123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CLOUDINARY CONFIGURATION (For Image Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- MOCK OTP CONFIG ---
MOCK_OTP=1234
