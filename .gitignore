# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/

# mypy / pyright
.mypy_cache/
.pyright/

# ─── SQLite local database ────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output
dist/
frontend/dist/
.vite/

# npm / yarn / pnpm lockfiles are usually committed, but logs are not
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
